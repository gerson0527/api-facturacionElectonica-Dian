# API
PORT=3000
NODE_ENV=development
BODY_SIZE_LIMIT=10mb
MULTIPART_FILE_SIZE_LIMIT=5242880
LOG_LEVEL=info

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=
DB_DATABASE=api_facturacion
DB_CA_CERT=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-key-64-chars-minimum!!
JWT_REFRESH_SECRET=change-me-refresh-secret-key-64-chars-minimum!!
JWT_ACCESS_EXPIRATION=60m
JWT_REFRESH_EXPIRATION=7d

# Encryption
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
ENCRYPTION_KEY_VERSION=1

# DIAN
DIAN_ENVIRONMENT=habilitacion
DIAN_HABILITACION_URL=https://vpfe-hab.dian.gov.co/WcfDianCustomerServices.svc
DIAN_PRODUCCION_URL=https://vpfe.dian.gov.co/WcfDianCustomerServices.svc
DIAN_TIMEOUT_CONNECTION=15000
DIAN_TIMEOUT_READ=60000
DIAN_TIMEOUT_TOTAL=120000

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate Limiting
THROTTLER_TTL=60
THROTTLER_LIMIT=30
THROTTLER_LIMIT_LOGIN=5

# Storage
STORAGE_PATH=./storage
XSD_PATH=./xsd

# Queue
QUEUE_SUBMISSION_MAX_ATTEMPTS=5
QUEUE_STATUS_MAX_ATTEMPTS=5

# Swagger
SWAGGER_ENABLED=true
